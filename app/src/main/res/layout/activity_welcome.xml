<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/welcome_gradient">

    <RelativeLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        tools:context=".WelcomeActivity"
        android:paddingBottom="24dp">

        <View
            android:id="@+id/logo_glow_bg"
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:background="@drawable/logo_glow"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="60dp"/>

        <ImageView
            android:id="@+id/logo"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@drawable/logo"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="100dp"
            android:contentDescription="Evanta Logo">
        </ImageView>

        <TextView
            android:id="@+id/welcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✨ Welcome to Evanta!"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:fontFamily="@font/poppins_semibold"
            android:layout_below="@+id/logo"
            android:layout_marginTop="24dp"
            android:layout_centerHorizontal="true">
        </TextView>

        <TextView
            android:id="@+id/tagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="-WHERE CAMPUS EVENTS COME ALIVE-"
            android:textColor="#B3FFFFFF"
            android:fontFamily="@font/poppins_semibold"
            android:textSize="@dimen/text_caption"
            android:letterSpacing="0.05"
            android:textAlignment="center"
            android:layout_below="@+id/welcome"
            android:layout_marginTop="4dp"
            android:layout_centerHorizontal="true">
        </TextView>

        <TextView
            android:id="@+id/description"
            android:layout_width="280dp"
            android:layout_height="wrap_content"
            android:text="Find fests, workshops, hackathons and competitions happening around your campus."
            android:textColor="#B4BCCB"
            android:fontFamily="@font/poppins_medium"
            android:textSize="@dimen/text_title"
            android:lineSpacingMultiplier="0.95"
            android:textAlignment="center"
            android:layout_below="@+id/tagline"
            android:layout_marginTop="24dp"
            android:layout_centerHorizontal="true">
        </TextView>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/getstart"
            android:layout_width="160dp"
            android:layout_height="@dimen/button_height"
            android:text="Get Started"
            android:fontFamily="@font/poppins_semibold"
            android:textSize="@dimen/text_title"
            android:layout_below="@+id/description"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="36dp"
            android:backgroundTint="@null"
            android:background="@drawable/btn_gradient"
            android:padding="8dp"
            android:textAllCaps="false"
            android:textColor="#FFFFFF">
        </androidx.appcompat.widget.AppCompatButton>

    </RelativeLayout>
</ScrollView>