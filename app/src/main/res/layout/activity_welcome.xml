<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".WelcomeActivity"
    android:background="@drawable/welcome_gradient">

    <View
        android:id="@+id/logo_glow_bg"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:background="@drawable/logo_glow"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="145dp"/>

    <ImageView
        android:id="@+id/logo"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/logo"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="180dp"
        android:contentDescription="Evanta Logo">
    </ImageView>

    <TextView
        android:id="@+id/welcome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✨ Welcome to Evanta!"
        android:textColor="#FFFFFF"
        android:textSize="25sp"
        android:fontFamily="@font/poppins_semibold"
        android:layout_below="@+id/logo"
        android:layout_marginTop="30dp"
        android:layout_centerHorizontal="true">
    </TextView>

    <TextView
        android:id="@+id/tagline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="-WHERE CAMPUS EVENTS COME ALIVE-"
        android:textColor="#B3FFFFFF"
        android:fontFamily="@font/poppins_semibold"
        android:textSize="13sp"
        android:letterSpacing="0.05"
        android:textAlignment="center"
        android:layout_below="@+id/welcome"
        android:layout_marginTop="6dp"
        android:layout_centerHorizontal="true">
    </TextView>

    <TextView
        android:id="@+id/description"
        android:layout_width="320dp"
        android:layout_height="wrap_content"
        android:text="Find fests, workshops, hackathons and competitions happening around your campus."
        android:textColor="#B4BCCB"
        android:fontFamily="@font/poppins_medium"
        android:textSize="17sp"
        android:lineSpacingMultiplier="0.95"
        android:textAlignment="center"
        android:layout_below="@+id/tagline"
        android:layout_marginTop="40dp"
        android:layout_centerHorizontal="true">
    </TextView>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/getstart"
        android:layout_width="180dp"
        android:layout_height="50dp"
        android:text="Get Started"
        android:fontFamily="@font/poppins_semibold"
        android:textSize="18sp"
        android:layout_below="@+id/description"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="50dp"
        android:backgroundTint="@null"
        android:background="@drawable/btn_gradient"
        android:padding="10dp"
        android:textAllCaps="false"
        android:textColor="#FFFFFF">
    </androidx.appcompat.widget.AppCompatButton>

</RelativeLayout>