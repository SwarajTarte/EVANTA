<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Fixed: logo + notification (mirrors student home top bar) -->
    <LinearLayout
        android:id="@+id/admin_top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="24dp"
        android:paddingBottom="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/admin_logo"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_weight="1"
            android:scaleType="fitStart"
            android:src="@drawable/logo2"
            android:contentDescription="Evanta" />

        <ImageView
            android:id="@+id/admin_notification_icon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="12dp"
            android:padding="4dp"
            android:src="@drawable/ic_notification"
            app:tint="#FFFFFF"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Notifications" />

    </LinearLayout>

    <!-- Fixed: greeting row -->
    <LinearLayout
        android:id="@+id/admin_greeting_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        app:layout_constraintTop_toBottomOf="@id/admin_top_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/admin_greeting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hi, there 👋"
                android:textSize="@dimen/text_display"
                android:textColor="#FFFFFF"
                android:fontFamily="@font/poppinsbold" />

            <TextView
                android:id="@+id/admin_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginRight="70dp"
                android:text="Manage the events you've created."
                android:textSize="@dimen/text_label"
                android:textColor="#8A93A6"
                android:fontFamily="@font/poppins_medium" />

        </LinearLayout>

        <FrameLayout
            android:layout_width="65dp"
            android:layout_height="65dp"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/admin_avatar_initial"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text=""
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:fontFamily="@font/poppinsbold"
                android:background="@drawable/bg_avatar_circle"
                android:includeFontPadding="false" />

            <ImageView
                android:id="@+id/admin_avatar_image"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone"
                android:scaleType="centerCrop"
                android:contentDescription="Profile photo" />

        </FrameLayout>

    </LinearLayout>

    <!-- Search bar (mirrors the student Browse tab) -->
    <EditText
        android:id="@+id/admin_events_search"
        android:layout_width="0dp"
        android:layout_height="@dimen/button_height"
        android:layout_marginTop="18dp"
        android:layout_marginHorizontal="20dp"
        android:background="@drawable/bg_search_bar"
        android:drawableStart="@drawable/ic_search_small"
        android:drawablePadding="10dp"
        android:paddingHorizontal="16dp"
        android:hint="Search your events..."
        android:textColorHint="#8A93A6"
        android:textColor="#FFFFFF"
        android:textSize="@dimen/text_body"
        android:fontFamily="@font/poppins_medium"
        android:singleLine="true"
        android:imeOptions="actionSearch"
        app:layout_constraintTop_toBottomOf="@id/admin_greeting_row"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Section label -->
    <TextView
        android:id="@+id/admin_events_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:paddingHorizontal="20dp"
        android:text="Your Events"
        android:textColor="#FFFFFF"
        android:textSize="@dimen/text_title"
        android:fontFamily="@font/poppinsbold"
        app:layout_constraintTop_toBottomOf="@id/admin_events_search"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Faded, scrolling list of event rows -->
    <com.evanta.app.FadingEdgeLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:fadeTop="true"
        app:fadeBottom="true"
        app:layout_constraintTop_toBottomOf="@id/admin_events_label"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/admin_events_recycler"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingTop="16dp"
            android:paddingBottom="120dp" />

    </com.evanta.app.FadingEdgeLayout>

    <ProgressBar
        android:id="@+id/admin_events_loader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/admin_events_label"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Empty / error state -->
    <LinearLayout
        android:id="@+id/admin_events_state"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/admin_events_label"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:src="@drawable/ic_empty_state"
            app:tint="#555B66" />

        <TextView
            android:id="@+id/admin_events_state_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="No Events Yet"
            android:textColor="#FFFFFF"
            android:textSize="@dimen/text_title"
            android:fontFamily="@font/poppins_semibold" />

        <TextView
            android:id="@+id/admin_events_state_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Create your first event from the Add tab."
            android:textColor="#8A93A6"
            android:textSize="@dimen/text_body"
            android:gravity="center"
            android:fontFamily="@font/poppinsreg" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
