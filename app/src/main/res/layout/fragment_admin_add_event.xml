<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_dashboard">

    <!-- ===== Fixed header ===== -->
    <FrameLayout
        android:id="@+id/add_back_button"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="40dp"
        android:background="@drawable/bg_circle_back"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_back_chevron"
            app:tint="#FFFFFF"
            android:contentDescription="Back" />
    </FrameLayout>

    <LinearLayout
        android:id="@+id/add_header_text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="14dp"
        app:layout_constraintTop_toTopOf="@id/add_back_button"
        app:layout_constraintBottom_toBottomOf="@id/add_back_button"
        app:layout_constraintStart_toEndOf="@id/add_back_button"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add New "
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:fontFamily="@font/poppinsbold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Event"
                android:textColor="#7C4DFF"
                android:textSize="24sp"
                android:fontFamily="@font/poppinsbold" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fill in the details to create a new event"
            android:textColor="#8A93A6"
            android:textSize="13sp"
            android:fontFamily="@font/poppins_medium" />
    </LinearLayout>

    <!-- ===== Scrollable form ===== -->
    <com.example.evanta.FadingEdgeLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:fadeTop="true"
        app:fadeBottom="true"
        app:fadeSize="20dp"
        app:layout_constraintTop_toBottomOf="@id/add_back_button"
        app:layout_constraintBottom_toTopOf="@id/create_event_button"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="20dp">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="none"
            android:clipToPadding="false"
            android:paddingTop="12dp"
            android:paddingBottom="16dp"
            android:paddingHorizontal="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- ===================== SECTION 1: BASIC INFO ===================== -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_form_section"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:gravity="center"
                            android:text="1"
                            android:textColor="#7C4DFF"
                            android:textSize="14sp"
                            android:fontFamily="@font/poppinsbold"
                            android:background="@drawable/bg_section_number" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:text="Basic Information"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp"
                            android:fontFamily="@font/poppins_semibold" />
                    </LinearLayout>

                    <!-- Event Title -->
                    <TextView style="@style/AddEventLabel" android:text="Event Title *" />

                    <EditText
                        android:id="@+id/input_title"
                        style="@style/AddEventField"
                        android:hint="Enter event title"
                        android:inputType="textCapWords" />

                    <!-- Category -->
                    <TextView style="@style/AddEventLabel" android:text="Category *" />

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:id="@+id/input_category"
                            style="@style/AddEventField"
                            android:hint="Select category"
                            android:clickable="true"
                            android:focusable="false"
                            android:gravity="center_vertical" />

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center_vertical|end"
                            android:layout_marginEnd="16dp"
                            android:src="@drawable/ic_chevron_down"
                            app:tint="#8A93A6" />
                    </FrameLayout>

                    <!-- Event Subtitle -->
                    <TextView style="@style/AddEventLabel" android:text="Subtitle *" />

                    <EditText
                        android:id="@+id/input_subtitle"
                        style="@style/AddEventField"
                        android:hint="Enter short event catchphrase"
                        android:inputType="textCapSentences" />

                    <!-- Description -->
                    <TextView style="@style/AddEventLabel" android:text="Description *" />

                    <EditText
                        android:id="@+id/input_description"
                        android:layout_width="match_parent"
                        android:layout_height="110dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_textfield"
                        android:gravity="top|start"
                        android:padding="14dp"
                        android:hint="Write a long layout description of the event"
                        android:textColorHint="#5A6377"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:fontFamily="@font/poppins_medium"
                        android:inputType="textMultiLine|textCapSentences"
                        android:maxLength="200" />

                    <TextView
                        android:id="@+id/counter_description"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:layout_marginTop="4dp"
                        android:text="0/200"
                        android:textColor="#5A6377"
                        android:textSize="11sp"
                        android:fontFamily="@font/poppins_medium" />
                </LinearLayout>

                <!-- ===================== SECTION 2: BANNER ===================== -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="vertical"
                    android:background="@drawable/bg_form_section"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:gravity="center"
                            android:text="2"
                            android:textColor="#7C4DFF"
                            android:textSize="14sp"
                            android:fontFamily="@font/poppinsbold"
                            android:background="@drawable/bg_section_number" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Event Banner"
                                android:textColor="#FFFFFF"
                                android:textSize="16sp"
                                android:fontFamily="@font/poppins_semibold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Upload a banner image for your event"
                                android:textColor="#8A93A6"
                                android:textSize="12sp"
                                android:fontFamily="@font/poppins_medium" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_banner_upload"
                        android:padding="18dp">

                        <FrameLayout
                            android:layout_width="90dp"
                            android:layout_height="90dp">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_gradient_tile"
                                android:padding="26dp"
                                android:src="@drawable/ic_image_placeholder"
                                app:tint="#FFFFFF"
                                android:scaleType="fitCenter" />

                            <ImageView
                                android:id="@+id/banner_preview"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerCrop"
                                android:visibility="gone"
                                android:contentDescription="Banner preview" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="16dp"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/banner_title"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Upload Banner Image"
                                android:textColor="#FFFFFF"
                                android:textSize="15sp"
                                android:fontFamily="@font/poppins_semibold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Recommended size: 16:9 ratio"
                                android:textColor="#8A93A6"
                                android:textSize="12sp"
                                android:fontFamily="@font/poppins_medium" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Max file size: 1MB"
                                android:textColor="#8A93A6"
                                android:textSize="12sp"
                                android:fontFamily="@font/poppins_medium" />

                            <TextView
                                android:id="@+id/choose_image_button"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:text="Choose Image"
                                android:textColor="#7C4DFF"
                                android:textSize="13sp"
                                android:fontFamily="@font/poppins_semibold"
                                android:background="@drawable/btn_outline_purple"
                                android:paddingHorizontal="20dp"
                                android:paddingVertical="9dp"
                                android:clickable="true"
                                android:focusable="true" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- ===================== SECTION 3: DATE & TIME ===================== -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="vertical"
                    android:background="@drawable/bg_form_section"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:gravity="center"
                            android:text="3"
                            android:textColor="#7C4DFF"
                            android:textSize="14sp"
                            android:fontFamily="@font/poppinsbold"
                            android:background="@drawable/bg_section_number" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:text="Date &amp; Time"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp"
                            android:fontFamily="@font/poppins_semibold" />
                    </LinearLayout>

                    <!-- Start Date + Start Time -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView style="@style/AddEventLabel" android:text="Start Date *" />

                            <TextView
                                android:id="@+id/input_start_date"
                                style="@style/AddEventField"
                                android:hint="Select start date"
                                android:clickable="true"
                                android:focusable="false"
                                android:gravity="center_vertical"
                                android:drawableStart="@drawable/ic_calendar_small"
                                android:drawablePadding="10dp"
                                app:drawableTint="#8A93A6" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:orientation="vertical">

                            <TextView style="@style/AddEventLabel" android:text="Start Time *" />

                            <TextView
                                android:id="@+id/input_start_time"
                                style="@style/AddEventField"
                                android:hint="Select start time"
                                android:clickable="true"
                                android:focusable="false"
                                android:gravity="center_vertical"
                                android:drawableStart="@drawable/ic_clock_small"
                                android:drawablePadding="10dp"
                                app:drawableTint="#8A93A6" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- End Date (no end time) -->
                    <TextView style="@style/AddEventLabel" android:text="End Date *" />

                    <TextView
                        android:id="@+id/input_end_date"
                        style="@style/AddEventField"
                        android:hint="Select end date"
                        android:clickable="true"
                        android:focusable="false"
                        android:gravity="center_vertical"
                        android:drawableStart="@drawable/ic_calendar_small"
                        android:drawablePadding="10dp"
                        app:drawableTint="#8A93A6" />

                    <!-- Registration Deadline -->
                    <TextView style="@style/AddEventLabel" android:text="Registration Deadline *" />

                    <TextView
                        android:id="@+id/input_reg_deadline"
                        style="@style/AddEventField"
                        android:hint="Select registration deadline"
                        android:clickable="true"
                        android:focusable="false"
                        android:gravity="center_vertical"
                        android:drawableStart="@drawable/ic_calendar_small"
                        android:drawablePadding="10dp"
                        app:drawableTint="#8A93A6" />
                </LinearLayout>

                <!-- ===================== SECTION 4: VENUE ===================== -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="vertical"
                    android:background="@drawable/bg_form_section"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:gravity="center"
                            android:text="4"
                            android:textColor="#7C4DFF"
                            android:textSize="14sp"
                            android:fontFamily="@font/poppinsbold"
                            android:background="@drawable/bg_section_number" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:text="Venue"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp"
                            android:fontFamily="@font/poppins_semibold" />
                    </LinearLayout>

                    <TextView style="@style/AddEventLabel" android:text="Venue / Location *" />

                    <EditText
                        android:id="@+id/input_location"
                        style="@style/AddEventField"
                        android:hint="Enter venue or location"
                        android:inputType="textCapWords"
                        android:focusable="true"
                        android:focusableInTouchMode="true" />

                    <TextView style="@style/AddEventLabel" android:text="City *" />

                    <EditText
                        android:id="@+id/input_city"
                        style="@style/AddEventField"
                        android:hint="Enter city"
                        android:inputType="textCapWords"
                        android:focusable="true"
                        android:focusableInTouchMode="true"
                        android:drawableStart="@drawable/ic_city_small"
                        android:drawablePadding="10dp"
                        app:drawableTint="#8A93A6" />
                </LinearLayout>

                <!-- ===================== SECTION 5: ADDITIONAL INFO ===================== -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="vertical"
                    android:background="@drawable/bg_form_section"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:gravity="center"
                            android:text="5"
                            android:textColor="#7C4DFF"
                            android:textSize="14sp"
                            android:fontFamily="@font/poppinsbold"
                            android:background="@drawable/bg_section_number" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:text="Additional Information"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp"
                            android:fontFamily="@font/poppins_semibold" />
                    </LinearLayout>

                    <TextView style="@style/AddEventLabel" android:text="Entry Fee" />

                    <EditText
                        android:id="@+id/input_price"
                        style="@style/AddEventField"
                        android:hint="Enter amount (0 for free)"
                        android:inputType="number"
                        android:focusable="true"
                        android:focusableInTouchMode="true"
                        android:drawableStart="@drawable/ic_rupee_small"
                        android:drawablePadding="10dp"
                        app:drawableTint="#8A93A6" />

                    <TextView style="@style/AddEventLabel" android:text="Maximum Participants" />

                    <EditText
                        android:id="@+id/input_capacity"
                        style="@style/AddEventField"
                        android:hint="Enter maximum limit (optional)"
                        android:inputType="number"
                        android:focusable="true"
                        android:focusableInTouchMode="true"
                        android:drawableStart="@drawable/ic_people_small"
                        android:drawablePadding="10dp"
                        app:drawableTint="#8A93A6" />

                    <!-- Featured toggle -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Feature this event"
                                android:textColor="#FFFFFF"
                                android:textSize="14sp"
                                android:fontFamily="@font/poppins_medium" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Show on the home featured carousel"
                                android:textColor="#8A93A6"
                                android:textSize="12sp"
                                android:fontFamily="@font/poppins_medium" />
                        </LinearLayout>

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/switch_featured"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </ScrollView>
    </com.example.evanta.FadingEdgeLayout>

    <!-- ===== Fixed Create button ===== -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/create_event_button"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="16dp"
        android:text="Create Event"
        android:textColor="#FFFFFF"
        android:textAllCaps="false"
        android:textSize="17sp"
        android:fontFamily="@font/poppins_semibold"
        android:background="@drawable/btn_gradient"
        app:backgroundTint="@null"
        app:cornerRadius="18dp"
        app:icon="@drawable/ic_admin_add_event"
        app:iconGravity="textStart"
        app:iconTint="#FFFFFF"
        app:iconPadding="8dp"
        app:iconSize="22dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ProgressBar
        android:id="@+id/create_event_progress"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:visibility="gone"
        android:indeterminateTint="#FFFFFF"
        app:layout_constraintTop_toTopOf="@id/create_event_button"
        app:layout_constraintBottom_toBottomOf="@id/create_event_button"
        app:layout_constraintEnd_toEndOf="@id/create_event_button"
        app:layout_constraintStart_toStartOf="@id/create_event_button" />

</androidx.constraintlayout.widget.ConstraintLayout>