<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_dashboard">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="24dp">

        <TextView
            android:id="@+id/profile_welcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome Back,"
            android:textSize="35sp"
            android:textColor="#FFFFFF"
            android:fontFamily="@font/poppinsbold"
            android:layout_marginTop="24dp"
            android:layout_marginLeft="20dp" />

        <RelativeLayout
            android:id="@+id/profile_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/profile_welcome"
            android:layout_marginTop="24dp"
            android:layout_marginLeft="16dp"
            android:layout_marginRight="16dp"
            android:background="@drawable/login_card"
            android:padding="24dp">

            <RelativeLayout
                android:id="@+id/avatar_ring"
                android:layout_width="98dp"
                android:layout_height="98dp"
                android:layout_centerHorizontal="true"
                android:background="@drawable/bg_avatar_ring">

                <TextView
                    android:id="@+id/avatar_initial"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text=""
                    android:textSize="34sp"
                    android:textColor="#FFFFFF"
                    android:fontFamily="@font/poppinsbold"
                    android:background="@drawable/bg_avatar_circle"
                    android:includeFontPadding="false"/>

                <ImageView
                    android:id="@+id/avatar_image"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="gone"
                    android:scaleType="centerCrop" />

            </RelativeLayout>

            <ImageView
                android:id="@+id/edit_avatar_icon"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_below="@+id/avatar_ring"
                android:layout_marginTop="-30dp"
                android:layout_alignRight="@+id/avatar_ring"
                android:layout_marginRight="-4dp"
                android:padding="6dp"
                android:src="@drawable/ic_edit_camera"
                android:background="@drawable/bg_avatar_circle"
                app:tint="#FFFFFF" />

            <TextView
                android:id="@+id/profile_full_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@+id/avatar_ring"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="16dp"
                android:text=""
                android:textSize="22sp"
                android:textColor="#FFFFFF"
                android:fontFamily="@font/poppinsbold" />

            <TextView
                android:id="@+id/profile_role_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@+id/profile_full_name"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="10dp"
                android:text="Student"
                android:textSize="13sp"
                android:textColor="#FFFFFF"
                android:fontFamily="@font/poppins_medium"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:background="@drawable/bg_role_badge" />

            <RelativeLayout
                android:id="@+id/info_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@+id/profile_role_badge"
                android:layout_marginTop="16dp"
                android:layout_marginLeft="16dp"
                android:layout_marginRight="16dp"
                android:background="@drawable/login_card"
                android:padding="20dp">

                <!-- Row 1: Full Name -->
                <ImageView
                    android:id="@+id/icon_name_row"
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:layout_marginTop="4dp"
                    android:src="@drawable/name_icon"
                    app:tint="#7C4DFF" />

                <TextView
                    android:id="@+id/label_name_row"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_toRightOf="@+id/icon_name_row"
                    android:layout_marginLeft="16dp"
                    android:text="Full Name"
                    android:textSize="13sp"
                    android:textColor="#B4BCCB"
                    android:fontFamily="@font/poppins_medium" />

                <TextView
                    android:id="@+id/value_name_row"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/label_name_row"
                    android:layout_toRightOf="@+id/icon_name_row"
                    android:layout_marginLeft="16dp"
                    android:layout_marginTop="2dp"
                    android:text=""
                    android:textSize="16sp"
                    android:textColor="#FFFFFF"
                    android:fontFamily="@font/poppins_medium" />

                <!-- Divider -->
                <View
                    android:id="@+id/divider1"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_below="@+id/value_name_row"
                    android:layout_marginTop="16dp"
                    android:background="#25FFFFFF" />

                <!-- Row 2: Email -->
                <ImageView
                    android:id="@+id/icon_email_row"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_below="@+id/divider1"
                    android:layout_marginTop="16dp"
                    android:src="@drawable/baseline_email_24"
                    app:tint="#7C4DFF" />

                <TextView
                    android:id="@+id/label_email_row"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignTop="@+id/icon_email_row"
                    android:layout_toRightOf="@+id/icon_email_row"
                    android:layout_marginLeft="16dp"
                    android:text="Email Address"
                    android:textSize="13sp"
                    android:textColor="#B4BCCB"
                    android:fontFamily="@font/poppins_medium" />

                <TextView
                    android:id="@+id/value_email_row"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/label_email_row"
                    android:layout_toRightOf="@+id/icon_email_row"
                    android:layout_marginLeft="16dp"
                    android:layout_marginTop="2dp"
                    android:text=""
                    android:textSize="16sp"
                    android:textColor="#FFFFFF"
                    android:fontFamily="@font/poppins_medium" />

                <!-- Divider -->
                <View
                    android:id="@+id/divider2"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_below="@+id/value_email_row"
                    android:layout_marginTop="16dp"
                    android:background="#25FFFFFF" />

                <!-- Row 3: WhatsApp -->
                <ImageView
                    android:id="@+id/icon_whatsapp_row"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_below="@+id/divider2"
                    android:layout_marginTop="16dp"
                    android:src="@drawable/whatsapp_icon"
                    app:tint="#7C4DFF" />

                <TextView
                    android:id="@+id/label_whatsapp_row"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignTop="@+id/icon_whatsapp_row"
                    android:layout_toRightOf="@+id/icon_whatsapp_row"
                    android:layout_marginLeft="16dp"
                    android:text="WhatsApp Number"
                    android:textSize="13sp"
                    android:textColor="#B4BCCB"
                    android:fontFamily="@font/poppins_medium" />

                <TextView
                    android:id="@+id/value_whatsapp_row"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/label_whatsapp_row"
                    android:layout_toRightOf="@+id/icon_whatsapp_row"
                    android:layout_marginLeft="16dp"
                    android:layout_marginTop="2dp"
                    android:text=""
                    android:textSize="16sp"
                    android:textColor="#FFFFFF"
                    android:fontFamily="@font/poppins_medium" />

            </RelativeLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/logoutbut"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_below="@+id/info_card"
                android:layout_marginTop="20dp"
                android:layout_marginLeft="16dp"
                android:layout_marginRight="16dp"
                android:text="Logout"
                android:textColor="#FFFFFF"
                android:textAllCaps="false"
                android:fontFamily="@font/poppins_semibold"
                android:textSize="18sp"
                android:background="@drawable/btn_gradient"
                app:backgroundTint="@null"
                app:icon="@drawable/ic_logout"
                app:iconGravity="textStart"
                app:iconTint="#FFFFFF"
                app:iconPadding="7dp"
                app:iconSize="25dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@+id/logoutbut"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="10dp"
                android:text="You will be logged out from your account"
                android:textSize="12sp"
                android:textColor="#8A93A6"
                android:fontFamily="@font/poppins_medium" />

        </RelativeLayout>

    </RelativeLayout>

</ScrollView>