<?xml version="1.0" encoding="utf-8"?>
<!-- dialog_manage_list.xml — shared shell for the Approvals and Certificates
     management dialogs shown from the admin event card banner buttons. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_content_card_top"
    android:padding="20dp">

    <TextView
        android:id="@+id/manage_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Enrollment Requests"
        android:textColor="#FFFFFF"
        android:textSize="@dimen/text_title"
        android:fontFamily="@font/poppinsbold" />

    <TextView
        android:id="@+id/manage_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Approve or reject students who registered."
        android:textColor="#8A93A6"
        android:textSize="@dimen/text_label"
        android:fontFamily="@font/poppins_medium" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="16dp"
        android:minHeight="120dp">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/manage_recycler"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxHeight="440dp"
            android:clipToPadding="false"
            android:paddingBottom="4dp" />

        <ProgressBar
            android:id="@+id/manage_loader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminateTint="#7C4DFF" />

        <TextView
            android:id="@+id/manage_empty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:paddingVertical="24dp"
            android:text="No students yet."
            android:textColor="#8A93A6"
            android:textSize="@dimen/text_body"
            android:fontFamily="@font/poppins_medium"
            android:visibility="gone" />

    </FrameLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/manage_close"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height"
        android:layout_marginTop="12dp"
        android:text="Done"
        android:textAllCaps="false"
        android:textColor="#B8A6FF"
        android:textSize="@dimen/text_title"
        android:fontFamily="@font/poppins_semibold" />

</LinearLayout>
