<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#181C25"
    app:strokeWidth="1dp"
    app:strokeColor="#2F3547">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Square Cover Image -->
        <ImageView
            android:id="@+id/event_cover"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:scaleType="centerCrop"
            android:src="@drawable/launcher"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Bottom fade overlay so it seamlessly blends with the card bg (#181C25) -->
        <View
            android:id="@+id/fade_overlay"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:background="@drawable/fade_bottom_overlay"
            app:layout_constraintBottom_toBottomOf="@id/event_cover"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Info Area below the image -->
        <TextView
            android:id="@+id/event_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginHorizontal="12dp"
            android:textSize="@dimen/text_title"
            android:textColor="#FFFFFF"
            android:maxLines="2"
            android:ellipsize="end"
            android:fontFamily="@font/poppins_semibold"
            android:text="Event Name"
            app:layout_constraintTop_toBottomOf="@id/event_cover"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Certificate download button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_download_certificate"
            android:layout_width="0dp"
            android:layout_height="@dimen/field_height"
            android:layout_marginTop="10dp"
            android:layout_marginHorizontal="12dp"
            android:layout_marginBottom="12dp"
            android:text="Certificate"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:textSize="@dimen/text_caption"
            app:backgroundTint="@null"
            app:strokeWidth="0dp"
            app:icon="@drawable/ic_book"
            app:iconGravity="textStart"
            app:iconSize="18dp"
            app:iconPadding="6dp"
            app:iconTint="@android:color/white"
            app:layout_constraintTop_toBottomOf="@id/event_title"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
