<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Fixed: logo + notification -->
    <LinearLayout
        android:id="@+id/home_top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="24dp"
        android:paddingBottom="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/home_logo"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_weight="1"
            android:scaleType="fitStart"
            android:src="@drawable/logo2"
            android:contentDescription="Evanta" />

        <ImageView
            android:id="@+id/home_notification_icon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="12dp"
            android:padding="4dp"
            android:src="@drawable/ic_notification"
            app:tint="#FFFFFF"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Notifications" />

    </LinearLayout>

    <!-- Fixed: greeting row -->
    <LinearLayout
        android:id="@+id/home_greeting_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        app:layout_constraintTop_toBottomOf="@id/home_top_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/home_greeting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hi, there 👋"
                android:textSize="20sp"
                android:textColor="#FFFFFF"
                android:fontFamily="@font/poppinsbold" />

            <TextView
                android:id="@+id/home_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginRight="70dp"
                android:text="Discover amazing events happening around your campus."
                android:textSize="13sp"
                android:textColor="#8A93A6"
                android:fontFamily="@font/poppins_medium" />

        </LinearLayout>

        <FrameLayout
            android:layout_width="65dp"
            android:layout_height="65dp"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/home_avatar_initial"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text=""
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:fontFamily="@font/poppinsbold"
                android:background="@drawable/bg_avatar_circle"
                android:includeFontPadding="false" />

            <ImageView
                android:id="@+id/home_avatar_image"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone"
                android:scaleType="centerCrop"
                android:contentDescription="Profile photo" />

        </FrameLayout>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/home_stats_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        app:layout_constraintTop_toBottomOf="@id/home_greeting_row"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="74dp"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:background="@drawable/bg_stat_card">

            <TextView
                android:id="@+id/stat_joined"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textSize="19sp"
                android:fontFamily="@font/poppinsbold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Joined"
                android:textColor="#8A93A6"
                android:textSize="11sp"
                android:fontFamily="@font/poppins_medium" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="74dp"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:background="@drawable/bg_stat_card">

            <TextView
                android:id="@+id/stat_upcoming"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textSize="19sp"
                android:fontFamily="@font/poppinsbold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Upcoming"
                android:textColor="#8A93A6"
                android:textSize="11sp"
                android:fontFamily="@font/poppins_medium" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="74dp"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:background="@drawable/bg_stat_card">

            <TextView
                android:id="@+id/stat_certificates"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textSize="19sp"
                android:fontFamily="@font/poppinsbold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Certificates"
                android:textColor="#8A93A6"
                android:textSize="11sp"
                android:fontFamily="@font/poppins_medium" />

        </LinearLayout>

    </LinearLayout>

    <!-- Fixed: "Featured Events" section header -->
    <LinearLayout
        android:id="@+id/featured_header_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        app:layout_constraintTop_toBottomOf="@id/home_stats_row"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Featured Events"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:fontFamily="@font/poppinsbold" />

        <TextView
            android:id="@+id/view_all_events"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="4dp"
            android:text="View All ›"
            android:textColor="#7C4DFF"
            android:textSize="13sp"
            android:fontFamily="@font/poppins_medium"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless" />

    </LinearLayout>

    <!-- fragment_home.xml — wrap the ScrollView in this instead -->
    <com.example.evanta.FadingEdgeLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/featured_header_row"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:scrollbars="none"
            android:paddingHorizontal="20dp"
            android:paddingTop="4dp"
            android:paddingBottom="100dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <include
                    android:layout_marginTop="15dp"
                    android:id="@+id/featured_card_1"
                    layout="@layout/item_featured_event"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone" />

                <include
                    android:id="@+id/featured_card_2"
                    layout="@layout/item_featured_event"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:visibility="gone" />

                <include
                    android:id="@+id/featured_card_3"
                    layout="@layout/item_featured_event"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:visibility="gone" />

            </LinearLayout>

        </ScrollView>

    </com.example.evanta.FadingEdgeLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
