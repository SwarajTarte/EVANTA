<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/login_gradient"
    tools:context=".LoginActivity"
    android:scrollbars="none">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="16dp">

        <View
            android:id="@+id/logo_glow_view"
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="1dp"
            android:background="@drawable/logo_glow" />

        <ImageView
            android:id="@+id/logo"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="45dp"
            android:src="@drawable/logo" />

        <ImageView
            android:id="@+id/logo2"
            android:layout_width="200dp"
            android:layout_height="75dp"
            android:layout_below="@+id/logo"
            android:layout_centerHorizontal="true"
            android:src="@drawable/logo2" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/logo2"
            android:layout_centerHorizontal="true"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/login_card"
            android:padding="16dp">

            <TextView
                android:id="@+id/newac"
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                android:background="@drawable/bg_textfield"
                android:fontFamily="@font/poppinsreg"
                android:text="New Account"
                android:textAlignment="center"
                android:textColor="#00D4FF"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/welcome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@+id/newac"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="6dp"
                android:fontFamily="@font/poppinsbold"
                android:text="Join EVANTA"
                android:textColor="#FFFFFF"
                android:textSize="24sp" />

            <TextView
                android:id="@+id/des"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@+id/welcome"
                android:layout_centerHorizontal="true"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:fontFamily="@font/poppinsreg"
                android:text="Create your account and start discovering campus events."
                android:textAlignment="center"
                android:textColor="#B4BCCB"
                android:textSize="14sp" />

            <!-- Input fields reduced to a compact 48dp height -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@+id/des"
                android:layout_marginTop="16dp"
                app:hintEnabled="false"
                app:startIconDrawable="@drawable/name_icon"
                app:startIconTint="#7C4DFF">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/nameIn"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_textfield"
                    android:fontFamily="@font/poppinsreg"
                    android:gravity="center_vertical"
                    android:hint="Full Name"
                    android:paddingTop="0dp"
                    android:paddingBottom="0dp"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#80FFFFFF"
                    android:textSize="14sp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/email"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@+id/name"
                android:layout_marginTop="8dp"
                app:hintEnabled="false"
                app:startIconDrawable="@drawable/baseline_email_24"
                app:startIconTint="#7C4DFF">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/emailin"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_textfield"
                    android:fontFamily="@font/poppinsreg"
                    android:gravity="center_vertical"
                    android:hint="Email Address"
                    android:paddingTop="0dp"
                    android:paddingBottom="0dp"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#80FFFFFF"
                    android:textSize="14sp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/whatsapp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@+id/email"
                android:layout_marginTop="8dp"
                app:hintEnabled="false"
                app:startIconDrawable="@drawable/whatsapp_icon"
                app:startIconTint="#7C4DFF">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/whatsappno"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_textfield"
                    android:fontFamily="@font/poppinsreg"
                    android:gravity="center_vertical"
                    android:hint="WhatsApp Number"
                    android:inputType="phone"
                    android:paddingTop="0dp"
                    android:paddingBottom="0dp"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#80FFFFFF"
                    android:textSize="14sp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/college_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@+id/whatsapp"
                android:layout_marginTop="8dp"
                app:hintEnabled="false"
                app:startIconDrawable="@drawable/ic_building_small"
                app:startIconTint="#7C4DFF">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/college_input"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_textfield"
                    android:clickable="true"
                    android:cursorVisible="false"
                    android:focusable="false"
                    android:fontFamily="@font/poppinsreg"
                    android:gravity="center_vertical"
                    android:hint="Select College"
                    android:paddingTop="0dp"
                    android:paddingBottom="0dp"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#80FFFFFF"
                    android:textSize="14sp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/branch_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@+id/college_layout"
                android:layout_marginTop="8dp"
                app:hintEnabled="false"
                app:startIconDrawable="@drawable/ic_branch"
                app:startIconTint="#7C4DFF">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/branch_input"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_textfield"
                    android:fontFamily="@font/poppinsreg"
                    android:gravity="center_vertical"
                    android:hint="Branch (e.g. Computer Science)"
                    android:paddingTop="0dp"
                    android:paddingBottom="0dp"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#80FFFFFF"
                    android:textSize="14sp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/password"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@+id/branch_layout"
                android:layout_marginTop="8dp"
                app:endIconMode="password_toggle"
                app:endIconTint="#FFFF"
                app:hintEnabled="false"
                app:startIconDrawable="@drawable/lock_icon"
                app:startIconTint="#7C4DFF">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/passwIn"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_textfield"
                    android:fontFamily="@font/poppinsreg"
                    android:gravity="center_vertical"
                    android:hint="Password"
                    android:inputType="textPassword"
                    android:paddingTop="0dp"
                    android:paddingBottom="0dp"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#80FFFFFF"
                    android:textSize="14sp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/confpassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@+id/password"
                android:layout_marginTop="8dp"
                app:endIconMode="password_toggle"
                app:endIconTint="#FFFF"
                app:hintEnabled="false"
                app:startIconDrawable="@drawable/lock_icon"
                app:startIconTint="#7C4DFF">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/confpasswordin"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_textfield"
                    android:fontFamily="@font/poppinsreg"
                    android:gravity="center_vertical"
                    android:hint="Confirm Password"
                    android:inputType="textPassword"
                    android:paddingTop="0dp"
                    android:paddingBottom="0dp"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#80FFFFFF"
                    android:textSize="14sp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/createac"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_below="@+id/confpassword"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="20dp"
                android:background="@drawable/btn_gradient"
                android:fontFamily="@font/poppins_semibold"
                android:text="Create Account"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                app:backgroundTint="@null"
                app:icon="@drawable/chevron_right"
                app:iconGravity="textEnd"
                app:iconPadding="5dp"
                app:iconSize="20dp"
                app:iconTint="#FFFFFF" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@+id/createac"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/alreadyac"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins_semibold"
                    android:text="Already have an account?"
                    android:textColor="#B4BCCB"
                    android:textSize="13sp"/>

                <TextView
                    android:id="@+id/signin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:fontFamily="@font/poppins_semibold"
                    android:text="Sign In"
                    android:textColor="#00D4FF"
                    android:textSize="14sp" />
            </LinearLayout>
        </RelativeLayout>
    </RelativeLayout>
</ScrollView>