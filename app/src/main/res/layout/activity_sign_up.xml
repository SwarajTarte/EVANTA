<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".LoginActivity"
    android:fillViewport="true"
    android:background="@drawable/login_gradient">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

    <View
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:background="@drawable/logo_glow"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="30dp">
    </View>

    <ImageView
        android:id="@+id/logo"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/logo"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="65dp">
    </ImageView>

    <ImageView
        android:id="@+id/logo2"
        android:layout_width="250dp"
        android:layout_height="100dp"
        android:layout_below="@+id/logo"
        android:layout_centerHorizontal="true"
        android:src="@drawable/logo2">
    </ImageView>

    <RelativeLayout
        android:layout_width="400dp"
        android:layout_height="wrap_content"
        android:layout_below="@+id/logo2"
        android:layout_centerHorizontal="true"
        android:background="@drawable/login_card"
        android:orientation="vertical">

        <TextView
            android:id="@+id/newac"
            android:layout_width="120dp"
            android:layout_height="wrap_content"
            android:text="New Account"
            android:textAlignment="center"
            android:fontFamily="@font/poppinsreg"
            android:textSize="14sp"
            android:textColor="#00D4FF"
            android:layout_marginTop="20dp"
            android:layout_centerHorizontal="true"
            android:background="@drawable/bg_textfield">
        </TextView>

        <TextView
            android:id="@+id/welcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Join EVANTA"
            android:fontFamily="@font/poppinsbold"
            android:textSize="30sp"
            android:textColor="#FFFFFF"
            android:layout_below="@+id/newac"
            android:layout_marginTop="5dp"
            android:layout_centerHorizontal="true">
        </TextView>

        <TextView
            android:id="@+id/des"
            android:layout_width="300dp"
            android:layout_height="wrap_content"
            android:text="Create your account and start discovering campus events."
            android:fontFamily="@font/poppinsreg"
            android:textSize="16sp"
            android:textAlignment="center"
            android:textColor="#B4BCCB"
            android:layout_below="@+id/welcome"
            android:layout_marginTop="-5dp"
            android:layout_centerHorizontal="true">
        </TextView>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/name"
            android:layout_width="350dp"
            android:layout_height="wrap_content"
            app:startIconDrawable="@drawable/name_icon"
            app:startIconTint="#7C4DFF"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="30dp"
            android:layout_below="@+id/des"
            app:hintEnabled="false">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/nameIn"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="Full Name"
                android:background="@drawable/bg_textfield"
                android:textColor="#FFFFFF"
                android:textColorHint="#80FFFFFF"
                android:fontFamily="@font/poppinsreg"
                android:gravity="center_vertical"
                android:paddingTop="0dp"
                android:paddingBottom="0dp"/>

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/email"
            android:layout_width="350dp"
            android:layout_height="wrap_content"
            app:startIconDrawable="@drawable/baseline_email_24"
            app:startIconTint="#7C4DFF"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="10dp"
            android:layout_below="@+id/name"
            app:hintEnabled="false">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/emailin"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="Email Address"
                android:background="@drawable/bg_textfield"
                android:textColor="#FFFFFF"
                android:textColorHint="#80FFFFFF"
                android:fontFamily="@font/poppinsreg"
                android:gravity="center_vertical"
                android:paddingTop="0dp"
                android:paddingBottom="0dp"/>

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/password"
            android:layout_width="350dp"
            android:layout_height="wrap_content"
            app:startIconDrawable="@drawable/lock_icon"
            app:startIconTint="#7C4DFF"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="10dp"
            app:endIconMode="password_toggle"
            app:endIconTint="#FFFF"
            android:layout_below="@+id/whatsapp"
            app:hintEnabled="false">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/passwIn"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="Password"
                android:background="@drawable/bg_textfield"
                android:textColor="#FFFFFF"
                android:textColorHint="#80FFFFFF"
                android:fontFamily="@font/poppinsreg"
                android:gravity="center_vertical"
                android:paddingTop="0dp"
                android:paddingBottom="0dp"
                android:inputType="textPassword"/>

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/confpassword"
            android:layout_width="350dp"
            android:layout_height="wrap_content"
            app:startIconDrawable="@drawable/lock_icon"
            app:startIconTint="#7C4DFF"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="10dp"
            app:endIconMode="password_toggle"
            app:endIconTint="#FFFF"
            android:layout_below="@+id/password"
            app:hintEnabled="false">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/confpasswordin"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="Confirm Password"
                android:background="@drawable/bg_textfield"
                android:textColor="#FFFFFF"
                android:textColorHint="#80FFFFFF"
                android:gravity="center_vertical"
                android:paddingTop="0dp"
                android:paddingBottom="0dp"
                android:fontFamily="@font/poppinsreg"
                android:inputType="textPassword"/>

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/whatsapp"
            android:layout_width="350dp"
            android:layout_height="wrap_content"
            app:startIconDrawable="@drawable/whatsapp_icon"
            app:startIconTint="#7C4DFF"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="10dp"
            android:layout_below="@+id/email"
            app:hintEnabled="false">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/whatsappno"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="WhatsApp Number"
                android:background="@drawable/bg_textfield"
                android:textColor="#FFFFFF"
                android:textColorHint="#80FFFFFF"
                android:gravity="center_vertical"
                android:paddingTop="0dp"
                android:paddingBottom="0dp"
                android:fontFamily="@font/poppinsreg"/>

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/createac"
            android:layout_width="350dp"
            android:layout_height="56dp"
            android:text="Create Account"
            android:textColor="#FFFFFF"
            android:textAllCaps="false"
            android:fontFamily="@font/poppins_semibold"
            android:textSize="18sp"
            android:background="@drawable/btn_gradient"
            app:icon="@drawable/chevron_right"
            app:iconSize="24dp"
            app:iconGravity="textEnd"
            app:iconPadding="5dp"
            app:iconTint="#FFFFFF"
            app:backgroundTint="@null"
            android:layout_below="@+id/confpassword"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="30dp">
        </com.google.android.material.button.MaterialButton>

        <RelativeLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@+id/createac"
            android:orientation="horizontal"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="50dp">

            <TextView
                android:id="@+id/alreadyac"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Already have an account?"
                android:layout_centerHorizontal="true"
                android:textColor="#B4BCCB"
                android:fontFamily="@font/poppins_semibold"/>

            <TextView
                android:id="@+id/signin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sign In"
                android:textSize="15sp"
                android:layout_centerHorizontal="true"
                android:textColor="#00D4FF"
                android:fontFamily="@font/poppins_semibold"
                android:layout_below="@+id/alreadyac"
                android:layout_marginBottom="20dp"/>
        </RelativeLayout>
    </RelativeLayout>
    </RelativeLayout>
</ScrollView>