<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="20dp"
    android:layout_marginBottom="14dp"
    android:background="@drawable/bg_event_row"
    android:padding="12dp">

    <FrameLayout
        android:id="@+id/event_thumbnail"
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:background="@drawable/bg_thumbnail_placeholder"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:id="@+id/event_thumbnail_image"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:visibility="gone" />

        <TextView
            android:id="@+id/event_thumbnail_text"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:padding="6dp"
            android:textColor="#FFFFFF"
            android:textSize="@dimen/text_label"
            android:fontFamily="@font/poppinsbold"
            android:maxLines="3" />

    </FrameLayout>

    <TextView
        android:id="@+id/event_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:textColor="#FFFFFF"
        android:textSize="@dimen/text_title"
        android:fontFamily="@font/poppinsbold"
        android:maxLines="1"
        android:ellipsize="end"
        app:layout_constraintTop_toTopOf="@id/event_thumbnail"
        app:layout_constraintStart_toEndOf="@id/event_thumbnail"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/event_category_tag"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="6dp"
        android:paddingHorizontal="10dp"
        android:paddingVertical="3dp"
        android:background="@drawable/bg_category_tag"
        android:textSize="@dimen/text_caption"
        android:fontFamily="@font/poppins_medium"
        app:layout_constraintTop_toBottomOf="@id/event_title"
        app:layout_constraintStart_toEndOf="@id/event_thumbnail" />

    <LinearLayout
        android:id="@+id/event_date_row"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintTop_toBottomOf="@id/event_category_tag"
        app:layout_constraintStart_toEndOf="@id/event_thumbnail">

        <ImageView
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:src="@drawable/ic_calendar_small"
            app:tint="#8A93A6" />

        <TextView
            android:id="@+id/event_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:textColor="#8A93A6"
            android:textSize="@dimen/text_caption"
            android:fontFamily="@font/poppins_medium" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/event_location_row"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="4dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintTop_toBottomOf="@id/event_date_row"
        app:layout_constraintStart_toEndOf="@id/event_thumbnail"
        app:layout_constraintEnd_toStartOf="@id/event_price">

        <ImageView
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:src="@drawable/ic_location_small"
            app:tint="#8A93A6" />

        <TextView
            android:id="@+id/event_location"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:textColor="#8A93A6"
            android:textSize="@dimen/text_caption"
            android:fontFamily="@font/poppins_medium"
            android:maxLines="1"
            android:ellipsize="end" />

    </LinearLayout>

    <TextView
        android:id="@+id/event_price"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="@dimen/text_label"
        android:fontFamily="@font/poppinsbold"
        app:layout_constraintBottom_toBottomOf="@id/event_thumbnail"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
