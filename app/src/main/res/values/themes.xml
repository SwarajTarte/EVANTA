<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Evanta" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <!-- Prevent Android from drawing a dark scrim over the transparent
             bars on API 29+, which otherwise breaks the seamless gradient. -->
        <item name="android:enforceStatusBarContrast" tools:targetApi="q">false</item>
        <item name="android:enforceNavigationBarContrast" tools:targetApi="q">false</item>
        <!-- Let the gradient run all the way to the edge of a gesture-nav bar. -->
        <item name="android:navigationBarDividerColor" tools:targetApi="o_mr1">@android:color/transparent</item>
    </style>

    <style name="Theme.Evanta" parent="Base.Theme.Evanta" />

    <!-- ===== Add Event form styles ===== -->
    <style name="AddEventLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">18dp</item>
        <item name="android:textColor">#B4BCCB</item>
        <item name="android:textSize">13sp</item>
        <item name="android:fontFamily">@font/poppins_medium</item>
    </style>

    <style name="AddEventField">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">54dp</item>
        <item name="android:layout_marginTop">6dp</item>
        <item name="android:background">@drawable/bg_textfield</item>
        <item name="android:paddingHorizontal">16dp</item>
        <item name="android:textColorHint">#5A6377</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">@font/poppins_medium</item>
        <item name="android:singleLine">true</item>
    </style>

    <style name="TransparentBottomSheet" parent="Theme.Material3.Light.BottomSheetDialog">
        <item name="android:background">@android:color/transparent</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="bottomSheetStyle">@style/TransparentBottomSheetStyle</item>
    </style>

    <style name="TransparentBottomSheetStyle" parent="Widget.Material3.BottomSheet.Modal">
        <item name="android:background">@android:color/transparent</item>
        <item name="backgroundTint">@android:color/transparent</item>
    </style>
</resources>